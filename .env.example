# Copy this file to .env and fill in your own values. NEVER commit .env.

# ── Required ───────────────────────────────────────────────────────────────────

# OpenAI API key (used to generate + rank replies).
OPENAI_API_KEY=sk-your-openai-key

# TwitterAPI.io API key (used to read the Twitter list timeline).
TWITTERAPI_KEY=your-twitterapi-io-key

# Numeric ID of the Twitter/X List to monitor.
# e.g. from https://x.com/i/lists/1234567890  ->  TWITTER_LIST_ID=1234567890
TWITTER_LIST_ID=

# Your own account's @handle, WITHOUT the leading @.
# Used only to strip the bot's own handle if the model echoes it.
BOT_HANDLE=your_handle

# ── Optional ───────────────────────────────────────────────────────────────────

# OpenAI model (default: gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# Persona / identity for the bot's voice.
# Either set PERSONA inline (single line) here, OR copy persona.example.txt to
# persona.txt for a multi-line persona. If neither is set, a neutral default
# ("You are a real human on Twitter...") is used.
# PERSONA=You are a real human on Twitter. NOT a brand account. NOT a bot.
# PERSONA_PATH=persona.txt

# SQLite database path (default: ./reply_guy.db).
DB_PATH=./reply_guy.db

# Path to your exported browser session cookies (default: cookies.json).
# On a host with a persistent volume, point this at the volume.
COOKIES_PATH=cookies.json

# Zernio (optional, not required for core functionality).
ZERNIO_API_KEY=
ZERNIO_ACCOUNT_ID=
